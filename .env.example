## Orchard.ai environment (copy to .env)
##
## Usage:
## - Copy: cp .env.example .env  (or duplicate the file in Windows Explorer)
## - Start: docker compose up -d --build
## - Verify: http://localhost:8080/api/ai/status

# Choose provider: local | auto | openai | anthropic | bedrock
AI_PROVIDER=local

## Local sovereign provider (Ollama)
LOCAL_AI_BASE_URL=http://ollama:11434
LOCAL_AI_MODEL=llama3.2:1b

## OpenAI (recommended quick start)
# OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

## Anthropic
# ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-latest

## AWS Bedrock
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_key_here
# AWS_SESSION_TOKEN=optional_session_token
AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

## Local model bootstrap (after docker compose up):
## docker compose exec ollama ollama pull llama3.2:1b

